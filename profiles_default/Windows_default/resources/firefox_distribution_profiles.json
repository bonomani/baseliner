{
  "policies": {
    "DisableTelemetry": true,
    "DisableFirefoxStudies": true,
    "DisablePocket": true,
    "DisableCrashReporter": true,
    "DisableFirefoxAccounts": true,

    "AppAutoUpdate": true,

    "DisableBuiltinPDFViewer": true,

    "Proxy": {
      "Mode": "autoDetect"
    },

    "SearchEngines": {
      "Default": "Google",
      "PreventInstalls": true
    },

    "Preferences": {
